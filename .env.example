# App
APP_ENV=local
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meetnotes
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meetnotes_test

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/connections/google/callback

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Google Workspace Events / Pub/Sub
# Leave the topic empty in local dev to skip creating event subscriptions.
WORKSPACE_EVENTS_TOPIC=
# PUSH_AUDIENCE and PUSH_SERVICE_ACCOUNT_EMAIL verify the Pub/Sub push token.
# MUST be set in production — empty values disable audience/service-account checks.
PUSH_AUDIENCE=
PUSH_SERVICE_ACCOUNT_EMAIL=

# Gemini (Google AI Studio) — required for notes generation / regenerate
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CHUNK_TOKEN_THRESHOLD=600000

# Background worker (arq) — empty disables the live worker; the API still records
# conferences durably so no work is lost until Redis is provisioned.
REDIS_URL=
